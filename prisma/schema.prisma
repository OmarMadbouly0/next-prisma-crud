generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Product {
  id         Int      @id @default(autoincrement())
  name       String
  price      Float
  categoryId Int                     
  category   Category @relation(fields: [categoryId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([name, categoryId])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique        
  products  Product[]               
  createdAt DateTime  @default(now())
}
